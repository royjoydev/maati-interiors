<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body>
  <%- include('partials/navbar') %>

  <div class="inquire-section">
    <div class="inquire-header">
      <h1><%= inquire.heading %></h1>
      <p><%= inquire.intro %></p>
      <p><%= inquire.subIntro %></p>
    </div>

    <form class="inquire-form" id="inquiryForm">

      <div class="form-group">
        <label>Full Name<span class="required">*</span></label>
        <input type="text" name="fullName" required>
      </div>

      <div class="form-group">
        <label>Email Address<span class="required">*</span></label>
        <input type="email" name="email" required>
      </div>

      <div class="form-group">
        <label>Phone Number<span class="required">*</span></label>
        <input type="tel" name="phone" required>
      </div>

      <div class="form-group">
        <label>Project Location (City, State)<span class="required">*</span></label>
        <input type="text" name="location" required>
      </div>

      <div class="form-group">
        <label>Project Type<span class="required">*</span></label>
        <select name="projectType" required>
          <option value="" selected>Please select</option>
          <% inquire.projectTypes.forEach(option => { %>
            <option value="<%= option %>"><%= option %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Which spaces are included?</label>
        <div class="checkbox-group">
          <% inquire.spaces.forEach(space => { %>
            <label class="checkbox-label">
              <input type="checkbox" name="spaces" value="<%= space %>">
              <span><%= space %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <div class="form-group">
        <label>Approximate Square Footage</label>
        <input type="text" name="squareFootage">
      </div>

      <div class="form-group">
        <label>Desired Start Timeframe<span class="required">*</span></label>
        <select name="timeframe" required>
          <option value="" selected>Please select</option>
          <% inquire.timeframes.forEach(option => { %>
            <option value="<%= option %>"><%= option %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Do you have a firm deadline?</label>
        <input type="text" name="deadline">
      </div>

      <div class="form-group">
        <p class="form-note"><%= inquire.budgetNote %></p>
        <label>Estimated Project Investment (Design + Furnishings)<span class="required">*</span></label>
        <select name="budget" required>
          <option value="" selected>Please select</option>
          <% inquire.budgetOptions.forEach(option => { %>
            <option value="<%= option %>"><%= option %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>How do you want your home to feel?</label>
        <textarea name="homeFeel" placeholder="Describe the feeling you're looking for..." rows="3"></textarea>
      </div>

      <div class="form-group">
        <label>What's currently not working in your space?</label>
        <textarea name="notWorking" placeholder="Tell us what you'd like to change..." rows="3"></textarea>
      </div>

      <div class="form-group">
        <label>Are you interested in sensory-friendly or wellness-focused design?</label>
        <select name="sensoryInterest">
          <option value="" selected>Please select</option>
          <% inquire.sensoryOptions.forEach(option => { %>
            <option value="<%= option %>"><%= option %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Tell us about your lifestyle or any specific needs</label>
        <textarea name="lifestyle" placeholder="Examples: kids, work-from-home, entertaining, sensitivities, etc." rows="3"></textarea>
      </div>

      <div class="form-group">
        <label>Are you the primary decision maker?</label>
        <select name="decisionMaker">
          <option value="" selected>Please select</option>
          <% inquire.decisionMaker.forEach(option => { %>
            <option value="<%= option %>"><%= option %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Have you worked with a designer before?</label>
        <select name="workedWithDesigner">
          <option value="" selected>Please select</option>
          <% inquire.workedWithDesigner.forEach(option => { %>
            <option value="<%= option %>"><%= option %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Inspiration Links (Pinterest, Instagram, etc.)</label>
        <input type="text" name="inspirationLinks" placeholder="Paste any links here...">
      </div>

      <div class="form-group">
        <label>Why are you looking to hire a designer right now?</label>
        <textarea name="whyNow" placeholder="What prompted you to reach out..." rows="3"></textarea>
      </div>

      <div class="form-submit">
        <button type="submit" class="btn btn-outline">SUBMIT INQUIRY</button>
      </div>
    </form>
  </div>

  <%- include('partials/footer') %>
  <script src="/js/script.js"></script>
</body>
</html>
