<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="page-home">
  <%- include('partials/navbar') %>

  <section class="hero-video">
    <video class="hero-video__media" autoplay muted loop playsinline poster="">
      <source src="/videos/hero-materials.mp4" type="video/mp4">
    </video>
    <div class="hero-video__overlay"></div>
    <div class="hero-video__content">
      <h1 class="hero-video__title">Residential and Commercial Design Studio</h1>
      <p class="hero-video__subtitle">With a thoughtful, intuitive approach, Maati Studio creates interiors that feel both elevated and deeply livable&mdash;spaces where everyday moments unfold with ease. Rooted in a respect for craftsmanship, timeless materials, and intentional design, each project blends practicality with quiet sophistication.</p>
    </div>
  </section>

  <section class="home-founder">
    <div class="home-founder__inner">
      <div class="home-founder__text">
        <h2 class="home-founder__heading">Meet Nilakshi Roy</h2>
        <p>The Founder and Principal Designer of Maati Interiors. Trained in architecture and deeply attuned to the emotional and sensory experience of space, she brings a thoughtful, human-centered perspective to every project. Her approach balances design precision with intuition &mdash; exploring how light, material, and proportion shape the way we feel in our homes.</p>
        <p>Nilakshi creates spaces that are not only beautiful, grounding, and quiet reflections of the people who live in the space.</p>
        <a href="/about" class="btn btn-outline">MORE ABOUT NILAKSHI</a>
      </div>
      <div class="home-founder__image">
        <img src="/images/about/nilakshi-portrait.jpg" alt="Nilakshi Roy, Founder and Principal Designer of Maati Interiors">
      </div>
    </div>
  </section>

  <section class="home-testimonials">
    <p class="home-testimonials__label">TESTIMONIALS</p>
    <div class="testimonial-slider" id="testimonialSlider">
      <% home.testimonials.forEach((t, i) => { %>
        <div class="testimonial-slide <%= i === 0 ? 'active' : '' %>">
          <p class="testimonial-mark">&ldquo;</p>
          <p class="testimonial-heading"><%= t.heading %></p>
          <p class="testimonial-quote"><%= t.quote %></p>
          <p class="testimonial-author">&mdash; <%= t.author %></p>
        </div>
      <% }) %>
    </div>
    <div class="testimonial-nav">
      <button class="testimonial-prev" id="testimonialPrev" aria-label="Previous testimonial">&larr;</button>
      <span class="testimonial-counter" id="testimonialCounter">1 / <%= home.testimonials.length %></span>
      <button class="testimonial-next" id="testimonialNext" aria-label="Next testimonial">&rarr;</button>
    </div>
  </section>

  <section class="start-project">
    <div class="start-project__image">
      <img src="/images/start-project.jpg" alt="Start your project with Maati Interiors">
    </div>
    <div class="start-project__text">
      <h2 class="start-project__heading">Start Your Project</h2>
      <p>You&rsquo;re just a phone call away from your dream space. We&rsquo;ll be happy to discuss ideas, provide estimates, and answer all your questions.</p>
      <a href="/inquire" class="btn btn-outline">INQUIRE</a>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/script.js"></script>
</body>
</html>
